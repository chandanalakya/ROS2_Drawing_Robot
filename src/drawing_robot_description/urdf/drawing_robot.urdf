<?xml version="1.0"?>
<robot name="drawing_robot">

  <!-- ================= BASE PLATFORM ================= -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <box size="0.6 0.6 0.05"/>
      </geometry>
      <material name="grey">
        <color rgba="0.7 0.7 0.7 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0"/>
      <geometry>
        <box size="0.6 0.6 0.05"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="5.0"/>
      <inertia
        ixx="0.1" ixy="0" ixz="0"
        iyy="0.1" iyz="0"
        izz="0.1"/>
    </inertial>
  </link>

  <!-- ================= X AXIS RAIL ================= -->
  <link name="x_axis">
    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <box size="0.5 0.05 0.05"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0"/>
      <geometry>
        <box size="0.5 0.05 0.05"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="1.0"/>
      <inertia
        ixx="0.02" ixy="0" ixz="0"
        iyy="0.02" iyz="0"
        izz="0.02"/>
    </inertial>
  </link>

  <!-- ================= Y AXIS CARRIAGE ================= -->
  <link name="y_axis">
    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <box size="0.05 0.4 0.05"/>
      </geometry>
      <material name="green">
        <color rgba="0 1 0 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0"/>
      <geometry>
        <box size="0.05 0.4 0.05"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.5"/>
      <inertia
        ixx="0.01" ixy="0" ixz="0"
        iyy="0.01" iyz="0"
        izz="0.01"/>
    </inertial>
  </link>

  <!-- ================= PEN TOOL ================= -->
  <link name="pen">
    <visual>
      <origin xyz="0 0 0" rpy="1.57 0 0"/>
      <geometry>
        <cylinder radius="0.01" length="0.1"/>
      </geometry>
      <material name="red">
        <color rgba="1 0 0 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.57 0 0"/>
      <geometry>
        <cylinder radius="0.01" length="0.1"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.1"/>
      <inertia
        ixx="0.001" ixy="0" ixz="0"
        iyy="0.001" iyz="0"
        izz="0.001"/>
    </inertial>
  </link>

  <!-- ================= JOINT: BASE → X AXIS ================= -->
  <joint name="x_joint" type="prismatic">
    <parent link="base_link"/>
    <child link="x_axis"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.25" upper="0.25" effort="10" velocity="0.5"/>
  </joint>

  <!-- ================= JOINT: X AXIS → Y AXIS ================= -->
  <joint name="y_joint" type="prismatic">
    <parent link="x_axis"/>
    <child link="y_axis"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.2" upper="0.2" effort="10" velocity="0.5"/>
  </joint>

  <!-- ================= JOINT: Y AXIS → PEN ================= -->
  <joint name="pen_joint" type="fixed">
    <parent link="y_axis"/>
    <child link="pen"/>
    <origin xyz="0 0 -0.1" rpy="0 0 0"/>
  </joint>

  <!-- ================= TRANSMISSIONS ================= -->
  <transmission name="x_joint_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="x_joint">
      <hardwareInterface>PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="x_joint_motor">
      <hardwareInterface>PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>

  <transmission name="y_joint_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="y_joint">
      <hardwareInterface>PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="y_joint_motor">
      <hardwareInterface>PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>

  <!-- ================= GAZEBO PLUGIN ================= -->
  <gazebo>
    <plugin name="gazebo_ros_control" filename="libgazebo_ros_control.so">
      <robotNamespace>/</robotNamespace>
    </plugin>
  </gazebo>

  <gazebo>
    <joint name="x_joint">
      <axis xyz="1 0 0"/>
      <dynamics damping="0.1" friction="0.2"/>
    </joint>
  </gazebo>

</robot>
